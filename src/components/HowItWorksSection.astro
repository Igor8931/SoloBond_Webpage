---
import IPhoneMockup from './IPhoneMockup.astro';

interface Props {
  content: {
    headline: string;
    step1: { title: string; description: string };
    step2: { title: string; description: string };
    step3: { title: string; description: string };
  };
}

const { content } = Astro.props;

const steps = [
  {
    ...content.step1,
    num: '01',
    imgSrc: '/images/screenshot-checkin.png',
    videoSrc: '/videos/checkin-flow.mp4',
    posterSrc: '/videos/checkin-flow-poster.jpg',
    alt: 'Check-in screen',
    rotation: 'left' as const,
    hasVideo: true,
  },
  {
    ...content.step2,
    num: '02',
    imgSrc: '/images/screenshot-done.png',
    videoSrc: '/videos/app-demo.mp4',
    posterSrc: '/videos/app-demo-poster.jpg',
    alt: 'Done screen with day colors',
    rotation: 'right' as const,
    hasVideo: true,
  },
  {
    ...content.step3,
    num: '03',
    imgSrc: '/images/screenshot_checkin_black.PNG',
    videoSrc: '',
    posterSrc: '',
    alt: 'Check-in screen dark mode',
    rotation: 'left' as const,
    hasVideo: false,
  },
];
---

<section class="how-it-works section" id="how-it-works">
  <div class="how-it-works__inner container">
    <h2 class="how-it-works__headline reveal">{content.headline}</h2>

    <div class="steps">
      {steps.map((step, i) => (
        <div class={`step step--${i % 2 === 0 ? 'normal' : 'reverse'}`}>
          <div class={`step__mockup reveal-up-far reveal-delay-${i + 1}`}>
            {/* Desktop: Show video if available, otherwise image */}
            {step.hasVideo ? (
              <>
                <div class="step__mockup-video">
                  <IPhoneMockup
                    src={step.videoSrc}
                    alt={step.alt}
                    type="video"
                    poster={step.posterSrc}
                    rotation={step.rotation}
                    size="medium"
                  />
                </div>
                <div class="step__mockup-image">
                  <IPhoneMockup
                    src={step.imgSrc}
                    alt={step.alt}
                    rotation={step.rotation}
                    size="medium"
                  />
                </div>
              </>
            ) : (
              <IPhoneMockup
                src={step.imgSrc}
                alt={step.alt}
                rotation={step.rotation}
                size="medium"
              />
            )}
          </div>
          <div class={`step__content reveal reveal-delay-${i + 1}`}>
            <span class="step__number">{step.num}</span>
            <h3 class="step__title">{step.title}</h3>
            <p class="step__description">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .how-it-works {
    position: relative;
    background-color: var(--color-bg-white);
    padding-block: var(--space-3xl);
  }

  /* Gradient fade from beige above */
  .how-it-works::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to bottom, var(--color-primary), var(--color-bg-white));
    pointer-events: none;
  }

  .how-it-works__headline {
    text-align: center;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    margin-bottom: var(--space-3xl);
    color: var(--color-text-dark);
  }

  .steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl);
  }

  .step {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .step__mockup {
    display: flex;
    justify-content: center;
  }

  .step__content {
    text-align: center;
  }

  .step__number {
    display: inline-block;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .step__title {
    font-size: clamp(1.375rem, 3vw, 1.75rem);
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text-dark);
  }

  .step__description {
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.65;
    color: var(--color-text-muted);
    max-width: 380px;
    margin-inline: auto;
  }

  /* Video/Image toggle: show video on desktop, image on mobile */
  .step__mockup-video {
    display: none;
  }

  .step__mockup-image {
    display: block;
  }

  /* Desktop: Alternating layout + show videos */
  @media (min-width: 768px) {
    .step {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }

    .step__content {
      text-align: left;
    }

    .step__description {
      margin-inline: 0;
    }

    .step--reverse {
      direction: rtl;
    }

    .step--reverse > * {
      direction: ltr;
    }

    .step--reverse .step__content {
      text-align: right;
    }

    .step--reverse .step__description {
      margin-left: auto;
    }

    /* Show video on desktop, hide static image */
    .step__mockup-video {
      display: block;
    }

    .step__mockup-image {
      display: none;
    }
  }
</style>
