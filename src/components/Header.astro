---
import LanguageSwitch from './LanguageSwitch.astro';

interface Props {
  content: {
    lang: string;
    nav: {
      howItWorks: string;
      getTheApp: string;
      faq: string;
      languageSwitch: string;
    };
  };
}

const { content } = Astro.props;
const lang = content.lang;
const isDE = lang === 'de';
const basePath = isDE ? '/de' : '';
---

<header class="header">
  <div class="header__inner container">
    <!-- Logo -->
    <a href={isDE ? '/de/' : '/'} class="header__logo" aria-label="SoloBond Home">
      <img
        src="/images/logo-full-transp.png"
        alt="SoloBond"
        width="140"
        height="40"
        class="header__logo-img"
      />
    </a>

    <!-- Desktop Navigation -->
    <nav class="header__nav" aria-label="Main navigation">
      <a href={`${basePath}/#how-it-works`} class="header__nav-link">
        {content.nav.howItWorks}
      </a>
      <a href={`${basePath}/#cta`} class="header__nav-link">
        {content.nav.getTheApp}
      </a>
      <a href={`${basePath}/#faq`} class="header__nav-link">
        {content.nav.faq}
      </a>
      <LanguageSwitch lang={lang} />
    </nav>

    <!-- Mobile Hamburger Button -->
    <button
      class="header__burger"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="header__burger-line"></span>
      <span class="header__burger-line"></span>
      <span class="header__burger-line"></span>
    </button>
  </div>

  <!-- Mobile Menu Overlay -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav class="mobile-menu__nav" aria-label="Mobile navigation">
      <a href={`${basePath}/#how-it-works`} class="mobile-menu__link">
        {content.nav.howItWorks}
      </a>
      <a href={`${basePath}/#cta`} class="mobile-menu__link">
        {content.nav.getTheApp}
      </a>
      <a href={`${basePath}/#faq`} class="mobile-menu__link">
        {content.nav.faq}
      </a>
      <div class="mobile-menu__lang">
        <LanguageSwitch lang={lang} />
      </div>
    </nav>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: var(--header-height);
    transition: background-color 0.4s ease, box-shadow 0.4s ease, backdrop-filter 0.4s ease;
  }

  /* Scrolled state — Glass Effect */
  .header:global(.header--scrolled) {
    background-color: rgba(240, 230, 216, 0.8);
    backdrop-filter: blur(20px) saturate(1.2);
    -webkit-backdrop-filter: blur(20px) saturate(1.2);
    box-shadow: 0 1px 0 rgba(42, 42, 42, 0.06), 0 4px 20px rgba(42, 42, 42, 0.04);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .header__logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    z-index: 1010;
  }

  .header__logo-img {
    width: 234px;
    height: auto;
    object-fit: contain;
  }

  /* Desktop nav */
  .header__nav {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .header__nav-link {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-dark);
    text-decoration: none;
    padding: 0.375rem 0;
    position: relative;
    transition: color var(--transition-fast);
  }

  .header__nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1.5px;
    background-color: var(--color-accent);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform var(--transition-base);
  }

  .header__nav-link:hover {
    color: var(--color-accent);
  }

  .header__nav-link:hover::after {
    transform: scaleX(1);
  }

  /* ========================================
     Hamburger Button (hidden on desktop)
     ======================================== */
  .header__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1010;
    -webkit-tap-highlight-color: transparent;
  }

  .header__burger-line {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-text-dark);
    border-radius: 2px;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.25s ease;
    transform-origin: center;
  }

  /* Burger → X animation */
  .header__burger[aria-expanded="true"] .header__burger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .header__burger[aria-expanded="true"] .header__burger-line:nth-child(2) {
    opacity: 0;
  }

  .header__burger[aria-expanded="true"] .header__burger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ========================================
     Mobile Menu Overlay (hidden on desktop)
     ======================================== */
  .mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: var(--color-bg-white);
    z-index: 1005;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 0;
    padding: var(--header-height) var(--space-lg) var(--space-lg);
  }

  .mobile-menu__link {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-dark);
    text-decoration: none;
    padding: 1.125rem 0;
    position: relative;
    opacity: 0;
    transform: translateY(16px);
    transition: color var(--transition-fast);
  }

  .mobile-menu__link:hover,
  .mobile-menu__link:active {
    color: var(--color-accent);
  }

  .mobile-menu__link::after {
    content: '';
    position: absolute;
    bottom: 0.5rem;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    width: 24px;
    height: 2px;
    background-color: var(--color-accent);
    border-radius: 1px;
    transition: transform var(--transition-base);
  }

  .mobile-menu__link:hover::after {
    transform: translateX(-50%) scaleX(1);
  }

  .mobile-menu__lang {
    margin-top: var(--space-lg);
    opacity: 0;
    transform: translateY(16px);
  }

  /* ========================================
     Mobile: < 768px
     ======================================== */
  @media (max-width: 767px) {
    .header__nav {
      display: none;
    }

    .header__burger {
      display: flex;
    }

    .mobile-menu {
      display: block;
    }

    .header__logo-img {
      width: 182px;
    }

    /* Open state */
    .mobile-menu:global(.is-open) {
      opacity: 1;
      visibility: visible;
    }

    .mobile-menu:global(.is-open) .mobile-menu__link,
    .mobile-menu:global(.is-open) .mobile-menu__lang {
      opacity: 1;
      transform: translateY(0);
    }

    .mobile-menu:global(.is-open) .mobile-menu__link:nth-child(1) {
      transition: opacity 0.4s 0.1s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  transform 0.4s 0.1s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  color var(--transition-fast);
    }
    .mobile-menu:global(.is-open) .mobile-menu__link:nth-child(2) {
      transition: opacity 0.4s 0.18s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  transform 0.4s 0.18s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  color var(--transition-fast);
    }
    .mobile-menu:global(.is-open) .mobile-menu__link:nth-child(3) {
      transition: opacity 0.4s 0.26s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  transform 0.4s 0.26s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  color var(--transition-fast);
    }
    .mobile-menu:global(.is-open) .mobile-menu__lang {
      transition: opacity 0.4s 0.34s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  transform 0.4s 0.34s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
  }
</style>

<script>
  // Mobile menu toggle
  const burger = document.querySelector('.header__burger') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = mobileMenu?.querySelectorAll('.mobile-menu__link');

  if (burger && mobileMenu) {
    const burgerEl = burger;
    const menuEl = mobileMenu;

    function openMenu() {
      burgerEl.setAttribute('aria-expanded', 'true');
      burgerEl.setAttribute('aria-label', 'Close menu');
      menuEl.classList.add('is-open');
      menuEl.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      burgerEl.setAttribute('aria-expanded', 'false');
      burgerEl.setAttribute('aria-label', 'Open menu');
      menuEl.classList.remove('is-open');
      menuEl.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    burgerEl.addEventListener('click', () => {
      const isOpen = burgerEl.getAttribute('aria-expanded') === 'true';
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    // Close on link click
    mobileLinks?.forEach((link) => {
      link.addEventListener('click', () => {
        closeMenu();
      });
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menuEl.classList.contains('is-open')) {
        closeMenu();
        burgerEl.focus();
      }
    });
  }
</script>
