---
import content from '../content/en.json';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  content={content}
  pageTitle="Privacy Policy — SoloBond"
  pageDescription="SoloBond Privacy Policy"
  canonicalPath="/privacy"
>
  <section class="section placeholder-page" style="padding-top: calc(var(--header-height) + var(--section-padding-y));">
    <div class="container container--narrow" style="text-align: center;">
      <h1>Privacy Policy</h1>
      <p style="margin-top: var(--space-md); color: var(--color-text-muted);">
        Our Privacy Policy is being finalized and will be published here before launch.
      </p>
    </div>
  </section>
</BaseLayout>
