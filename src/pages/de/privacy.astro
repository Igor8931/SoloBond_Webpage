---
import content from '../../content/de.json';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  content={content}
  pageTitle="Datenschutz — SoloBond"
  pageDescription="SoloBond Datenschutzerkl&auml;rung"
  canonicalPath="/de/privacy"
>
  <section class="section placeholder-page" style="padding-top: calc(var(--header-height) + var(--section-padding-y));">
    <div class="container container--narrow" style="text-align: center;">
      <h1>Datenschutz</h1>
      <p style="margin-top: var(--space-md); color: var(--color-text-muted);">
        Unsere Datenschutzerkl&auml;rung wird derzeit finalisiert und vor dem Launch hier ver&ouml;ffentlicht.
      </p>
    </div>
  </section>
</BaseLayout>
