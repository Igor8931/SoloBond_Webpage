---
import content from '../../content/de.json';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  content={content}
  pageTitle="Impressum & AGB — SoloBond"
  pageDescription="SoloBond Impressum und AGB"
  canonicalPath="/de/legal"
>
  <section class="section placeholder-page" style="padding-top: calc(var(--header-height) + var(--section-padding-y));">
    <div class="container container--narrow" style="text-align: center;">
      <h1>Impressum & AGB</h1>
      <p style="margin-top: var(--space-md); color: var(--color-text-muted);">
        Unser Impressum und unsere AGB werden derzeit finalisiert und vor dem Launch hier ver&ouml;ffentlicht.
      </p>
    </div>
  </section>
</BaseLayout>
