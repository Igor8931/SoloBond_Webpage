---
import content from '../content/en.json';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  content={content}
  pageTitle="Legal Notice — SoloBond"
  pageDescription="Legal Notice (Impressum) for SoloBond, pursuant to § 5 DDG (German Digital Services Act)."
  canonicalPath="/legal"
>
  <article class="legal-page">
    <div class="legal-page__inner">
      <header class="legal-page__header">
        <h1 class="legal-page__title">Legal Notice</h1>
      </header>

      <div class="legal-page__content">

        <section class="legal-section">
          <h2>Information pursuant to &sect; 5 DDG (German Digital Services Act)</h2>
          <address class="legal-address">
            Igor Baum<br />
            c/o IP-Management #8358<br />
            Ludwig-Erhard-Stra&szlig;e 18<br />
            20459 Hamburg<br />
            Germany
          </address>
          <p>Email: <a href="mailto:team@solobond.app">team@solobond.app</a></p>
        </section>

        <section class="legal-section">
          <h2>Responsible for content pursuant to &sect; 18(2) MStV</h2>
          <p>Igor Baum<br />Address as above</p>
        </section>

        <section class="legal-section">
          <h2>VAT ID</h2>
          <p>No VAT identification number available.</p>
        </section>

        <section class="legal-section">
          <h2>Online Dispute Resolution (Art. 14(1) ODR Regulation)</h2>
          <p>The European Commission provides a platform for online dispute resolution:<br />
            <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener noreferrer">https://ec.europa.eu/consumers/odr/</a>
          </p>
          <p>We are neither obligated nor willing to participate in dispute resolution proceedings before a consumer arbitration board.</p>
        </section>

      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .legal-page {
    padding-top: calc(var(--header-height) + var(--space-xl));
    padding-bottom: var(--space-3xl);
    background-color: var(--color-bg-white);
    min-height: 100vh;
  }

  .legal-page__inner {
    max-width: 800px;
    margin-inline: auto;
    padding-inline: var(--section-padding-x);
  }

  .legal-page__header {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border-light);
  }

  .legal-page__title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 5vw, 2.75rem);
    color: var(--color-text-dark);
    line-height: 1.2;
  }

  /* Section Blocks */
  .legal-section {
    margin-bottom: var(--space-xl);
  }

  .legal-section:last-child {
    margin-bottom: 0;
  }

  .legal-section h2 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(1.25rem, 3vw, 1.5rem);
    color: var(--color-text-dark);
    line-height: 1.3;
    margin-bottom: var(--space-sm);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border-light);
  }

  .legal-section:first-child h2 {
    border-top: none;
    padding-top: 0;
  }

  /* Body text */
  .legal-section p {
    margin-bottom: 0.75rem;
    line-height: 1.75;
    color: var(--color-text-dark);
  }

  .legal-section p:last-child {
    margin-bottom: 0;
  }

  /* Links */
  .legal-section a,
  .legal-address a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: rgba(232, 120, 92, 0.3);
    transition: text-decoration-color var(--transition-fast);
  }

  .legal-section a:hover,
  .legal-address a:hover {
    text-decoration-color: var(--color-accent);
  }

  /* Address blocks */
  .legal-address {
    font-style: normal;
    line-height: 1.75;
    margin-bottom: 0.75rem;
    color: var(--color-text-dark);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .legal-page {
      padding-top: calc(var(--header-height) + var(--space-lg));
      padding-bottom: var(--space-xl);
    }
  }
</style>
