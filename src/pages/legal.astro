---
import content from '../content/en.json';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  content={content}
  pageTitle="Legal Terms — SoloBond"
  pageDescription="SoloBond Legal Terms"
  canonicalPath="/legal"
>
  <section class="section placeholder-page" style="padding-top: calc(var(--header-height) + var(--section-padding-y));">
    <div class="container container--narrow" style="text-align: center;">
      <h1>Legal Terms</h1>
      <p style="margin-top: var(--space-md); color: var(--color-text-muted);">
        Our Legal Terms are being finalized and will be published here before launch.
      </p>
    </div>
  </section>
</BaseLayout>
